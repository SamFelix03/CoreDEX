{
  "name": "coredex-smart-contracts",
  "version": "1.0.0",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "build:rust": "cd rust-contracts && npm run build",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:assethub": "hardhat run scripts/deploy.ts --network assetHub",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network assetHubMainnet",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network polkadotTestNet",
    "deploy:pvm": "hardhat run scripts/deploy-pvm-mocks.ts --network localhost",
    "deploy:pvm:testnet": "hardhat run scripts/deploy-pvm-mocks.ts --network polkadotTestNet",
    "simulate": "hardhat run scripts/simulate-coredex.ts --network localhost",
    "simulate:fork": "hardhat run scripts/simulate-coredex.ts --network localhost",
    "registry:sync-deployed": "hardhat run scripts/register-deployed-in-registry.ts --network polkadotTestNet",
    "demo:mint-region": "hardhat run scripts/mint-demo-region.ts --network polkadotTestNet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.3.0"
  },
  "dependencies": {
    "@polkadot/api": "^16.5.4",
    "@polkadot/keyring": "^14.0.1",
    "@polkadot/util-crypto": "^14.0.1"
  }
}
